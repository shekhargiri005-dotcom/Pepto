# Frontend environment variables — copy to .env.local and fill in your values
# NEVER commit .env.local to version control

# ── API & Backend ─────────────────────────────────────────────────────────────
# Base URL for all REST API calls (no trailing slash)
VITE_API_BASE_URL=http://localhost:5000

# Socket.IO server URL (usually same host as API)
VITE_SOCKET_URL=http://localhost:5000

# ── Stripe (Payments) ─────────────────────────────────────────────────────────
# Use a pk_test_ key during development — NEVER use your live key here
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_51...your_key_here

# ── Mapbox (Maps & Geolocation) ───────────────────────────────────────────────
# Get a free token at https://account.mapbox.com/
VITE_MAPBOX_TOKEN=

# ── Cloudinary (Image Uploads / CDN) ─────────────────────────────────────────
# Your Cloudinary cloud name (visible on dashboard)
VITE_CLOUDINARY_CLOUD_NAME=

# ── Feature Flags (optional) ──────────────────────────────────────────────────
# Set to 'true' to enable features still in development
VITE_ENABLE_CHAT=true
VITE_ENABLE_SUBSCRIPTION=false

# ── App Metadata ──────────────────────────────────────────────────────────────
VITE_APP_NAME=Pepto
VITE_APP_VERSION=1.0.0
VITE_SENTRY_DSN=
